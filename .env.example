# ==========================================
# WATER QUALITY MONITOR - GLOBAL API KEYS
# ==========================================
# Copy this file to '.env' and fill in your keys.
# The Docker containers and frontend will automatically read from here.

# 1. Copernicus Satellite Data (dataspace.copernicus.eu)
COPERNICUS_CLIENT_ID=your_copernicus_client_id_here
COPERNICUS_CLIENT_SECRET=your_copernicus_client_secret_here

# 2. Google Maps 3D Tiles (console.cloud.google.com)
# Enables photorealistic 3D terrain on the frontend
GOOGLE_API_KEY=your_google_api_key_here

# 3. Environment Agency (UK Gov - Open Data)
# Note: Currently free/open, but if they reinstate rate-limit keys in the future, add it here.
EA_API_KEY=optional_uk_gov_key_here

# 4. Database Config (Defaults provided for Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=water_quality
